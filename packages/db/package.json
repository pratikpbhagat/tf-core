{
  "name": "@tf-core/db",
  "private": true,
  "version": "0.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "reset": "supabase db reset",
    "gen:types": "supabase gen types typescript --local > src/types.ts",
    "gen:types:remote": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" > src/types.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tf-core/config": "workspace:*",
    "supabase": "^2.101.0",
    "typescript": "^5.6.0"
  }
}
